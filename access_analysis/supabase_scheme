-- ── Useful query examples ─────────────────────────────────────────────────────

-- Historical average per user (used by baseline engine):
-- SELECT AVG(access_risk) FROM security_logs WHERE user_id = 'alice';

-- Recent logs for session reconstruction:
-- SELECT timestamp, input_hash FROM security_logs
--   WHERE user_id = 'alice'
--   ORDER BY timestamp DESC LIMIT 20;

-- Decision distribution for a user:
-- SELECT decision, COUNT(*) FROM security_logs
--   WHERE user_id = 'alice'
--   GROUP BY decision;

-- Users with BLOCK events in the last 24 hours:
-- SELECT DISTINCT user_id FROM security_logs
--   WHERE decision = 'BLOCK'
--     AND timestamp >= NOW() - INTERVAL '24 hours';
