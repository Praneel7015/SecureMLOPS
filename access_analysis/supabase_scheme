-- security_logs: append-only audit log
-- Rows are NEVER updated. Every request produces exactly one row.
CREATE TABLE IF NOT EXISTS security_logs (
    id              BIGSERIAL    PRIMARY KEY,
    user_id         TEXT         NOT NULL,
    timestamp       TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    access_risk     FLOAT        NOT NULL,   -- session-level behavioural risk
    final_risk      FLOAT        NOT NULL,   -- baseline-adjusted final risk
    decision        TEXT         NOT NULL,   -- ALLOW | MONITOR | BLOCK
    reason          TEXT         NOT NULL,   -- human-readable explanation
    request_type    TEXT         NOT NULL DEFAULT 'inference',
    response_status TEXT         NOT NULL,
    input_hash      TEXT         NOT NULL    -- SHA-256 of input identifier
);

-- Index speeds up per-user history queries
CREATE INDEX IF NOT EXISTS idx_security_logs_user_id
    ON security_logs (user_id);

